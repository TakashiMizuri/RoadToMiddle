{

  "name": "road-to-middle-app",

  "private": true,

  "version": "0.1.0",

  "type": "module",

  "main": "electron-dist/main.mjs",

  "scripts": {

    "parse-roadmap": "tsx ../scripts/parse-roadmap.ts",

    "predev": "npm run parse-roadmap",

    "prebuild": "npm run parse-roadmap",

    "dev": "vite",

    "dev:server": "vite",

    "build": "tsc && vite build",

    "preview": "vite preview",

    "tauri": "tauri",

    "electron:compile:preload": "esbuild electron/preload.ts --bundle --platform=node --format=cjs --outfile=electron/preload.cjs --external:electron",

    "electron:compile:main": "esbuild electron/main.ts --bundle --platform=node --format=esm --outfile=electron-dist/main.mjs --external:electron --packages=external",

    "desktop:dev": "node scripts/dev.mjs",

    "desktop:build": "cross-env ELECTRON=1 npm run build && npm run electron:compile:preload && npm run electron:compile:main && electron-builder --win",

    "postinstall": "electron-rebuild -f -w better-sqlite3"

  },

  "dependencies": {

    "@tailwindcss/typography": "^0.5.20",

    "@tanstack/react-virtual": "^3.13.12",

    "@tauri-apps/api": "^2",

    "@tauri-apps/plugin-dialog": "^2",

    "@tauri-apps/plugin-fs": "^2",

    "@tauri-apps/plugin-notification": "^2",

    "@tauri-apps/plugin-opener": "^2",

    "better-sqlite3": "^11.10.0",

    "clsx": "^2.1.1",

    "highlight.js": "^11.11.1",

    "lucide-react": "^0.525.0",

    "mermaid": "^11.9.0",

    "react": "^19.1.0",

    "react-dom": "^19.1.0",

    "react-markdown": "^10.1.0",

    "recharts": "^3.1.0",

    "rehype-highlight": "^7.0.2",

    "remark-gfm": "^4.0.1",

    "tailwind-merge": "^3.3.1",

    "zustand": "^5.0.6"

  },

  "devDependencies": {

    "@tailwindcss/vite": "^4.1.11",

    "@tauri-apps/cli": "^2",

    "@types/better-sqlite3": "^7.6.13",

    "@types/react": "^19.1.8",

    "@types/react-dom": "^19.1.6",

    "@vitejs/plugin-react": "^4.6.0",

    "concurrently": "^9.2.0",

    "cross-env": "^7.0.3",

    "electron": "^35.1.5",

    "electron-builder": "^26.0.12",

    "esbuild": "^0.25.5",

    "tailwindcss": "^4.1.11",

    "tsx": "^4.20.3",

    "typescript": "~5.8.3",

    "vite": "^7.0.4",

    "wait-on": "^8.0.3"

  },

  "build": {

    "appId": "com.roadtomiddle.app",

    "productName": "Road to Middle",

    "directories": {

      "output": "release"

    },

    "files": [

      "dist/**/*",

      "electron/preload.cjs",

      "electron-dist/main.mjs",

      "package.json",

      "node_modules/better-sqlite3/**/*"

    ],

    "asarUnpack": [

      "**/node_modules/better-sqlite3/**"

    ],

    "win": {

      "target": [

        "nsis"

      ]

    },

    "nsis": {

      "oneClick": false,

      "allowToChangeInstallationDirectory": true

    }

  }

}


